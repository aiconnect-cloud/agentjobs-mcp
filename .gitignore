# ============================================================
# Dependencies
# ============================================================
node_modules/
.npm

# ============================================================
# Build output
# ============================================================
build/
dist/
out/
*.tsbuildinfo

# Defensive: src/ deve permanecer 100% TypeScript.
# O loader dinâmico (src/index.ts) importa .js de build/tools/ em runtime;
# qualquer .js solto em src/ pode causar comportamento inesperado.
src/**/*.js

# ============================================================
# Test coverage
# ============================================================
coverage/
*.lcov

# ============================================================
# Logs
# ============================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

